generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LoanType {
  SOLICITADO
  PRESTADO
}

enum UnitType {
  UNIDADES
  CAJAS
}

model Hospital {
  id        String   @id @default(cuid())
  name      String
  email     String?
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  loans     Loan[]

  @@map("hospitals")
}

model Medication {
  id               String     @id @default(cuid())
  name             String
  nationalCode     String?    @map("national_code")
  presentation     String?
  activeIngredient String?    @map("active_ingredient")
  active           Boolean    @default(true)
  isAutoCreated    Boolean    @default(false) @map("is_auto_created")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  loanItems        LoanItem[]

  @@map("medications")
}

model Loan {
  id                    String     @id @default(cuid())
  referenceNumber       String     @unique @map("reference_number")
  type                  LoanType
  hospitalId            String     @map("hospital_id")
  hospital              Hospital   @relation(fields: [hospitalId], references: [id])
  farmatoolsGestionado  Boolean    @default(false) @map("farmatools_gestionado")
  devuelto              Boolean    @default(false)
  emailSentTo           String?    @map("email_sent_to")
  pdfUrl                String?    @map("pdf_url")
  notes                 String?
  pharmacistName        String?    @map("pharmacist_name")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  items                 LoanItem[]

  @@index([hospitalId])
  @@index([farmatoolsGestionado])
  @@index([devuelto])
  @@index([type])
  @@index([createdAt])
  @@map("loans")
}

model LoanItem {
  id           String     @id @default(cuid())
  loanId       String     @map("loan_id")
  loan         Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)
  medicationId String     @map("medication_id")
  medication   Medication @relation(fields: [medicationId], references: [id])
  units        Int
  unitType     UnitType   @default(UNIDADES) @map("unit_type")

  @@index([loanId])
  @@index([medicationId])
  @@map("loan_items")
}

model SmtpSettings {
  id        String  @id @default("default")
  host      String
  port      Int
  secure    Boolean @default(false)
  user      String
  password  String
  fromName  String  @map("from_name")
  fromEmail String  @map("from_email")
  ccEmail   String? @map("cc_email")

  @@map("smtp_settings")
}

model ReferenceCounter {
  id      String @id @default("loan_counter")
  year    Int
  counter Int    @default(0)

  @@map("reference_counters")
}
